+
+    run_month(cfg, "2025-01", no_site=True, feature_paper="2501.00001")
+
+    digest = json.loads((cfg.output_dir / "2025-01" / "digest.json").read_text(encoding="utf-8"))
+    assert digest["featured_paper"] == "2501.00001"
